{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Next.js Dev",
      "runtimeExecutable": "/usr/local/bin/node",
      "runtimeArgs": ["node_modules/.bin/next", "dev", "--port", "3000"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "Next.js Dev (Sprint A)",
      "runtimeExecutable": "/usr/local/bin/node",
      "runtimeArgs": ["node_modules/.bin/next", "dev", "--port", "3456"],
      "port": 3456,
      "autoPort": true
    },
    {
      "name": "Next.js Dev (webpack)",
      "runtimeExecutable": "/bin/sh",
      "runtimeArgs": ["-c", "PATH=/usr/local/bin:$PATH node_modules/.bin/next dev --webpack --port ${PORT:-3001}"],
      "port": 3001,
      "autoPort": true
    },
    {
      "name": "Next.js Dev (Staging)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev:staging"],
      "port": 3000
    },
    {
      "name": "Next.js Dev (Coming Soon)",
      "runtimeExecutable": "/bin/sh",
      "runtimeArgs": ["-c", "COMING_SOON_MODE=true PATH=/usr/local/bin:$PATH node_modules/.bin/next dev --port ${PORT:-3002}"],
      "port": 3002,
      "autoPort": true
    },
    {
      "name": "Supabase Edge Functions",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "functions:serve"],
      "port": 54321
    }
  ]
}
