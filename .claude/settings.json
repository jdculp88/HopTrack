{
  "$schema": "https://code.claude.com/schema/settings.json",
  "_comment": "HopTrack — Sprint 173 — 'The Harness'. Project-level Claude Code config: permissions allow/deny, hook wiring, MCP references. Committed to git (this file), runs for every teammate who clones the repo. Personal overrides live in .claude/settings.local.json (gitignored).",

  "permissions": {
    "deny": [
      "Bash(git reset --hard *)",
      "Bash(git push --force *)",
      "Bash(git push --force-with-lease *)",
      "Bash(git checkout -- *)",
      "Bash(git clean -fd*)",
      "Bash(git clean -f *)",
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf .git)",
      "Bash(rm -rf .git/*)",
      "Bash(rm -rf node_modules)",
      "Bash(rm -rf *.lock)",
      "Bash(psql * DROP TABLE *)",
      "Bash(psql * DROP DATABASE *)",
      "Bash(psql * TRUNCATE *)",
      "Bash(supabase db reset *)",
      "Bash(supabase projects delete *)"
    ],
    "allow": [
      "Bash(npm run lint)",
      "Bash(npm run lint *)",
      "Bash(npm run test)",
      "Bash(npm run test *)",
      "Bash(npm test)",
      "Bash(npm test *)",
      "Bash(npm run test:coverage)",
      "Bash(npm run test:e2e)",
      "Bash(npm run test:e2e *)",
      "Bash(npm run build)",
      "Bash(npm run dev)",
      "Bash(npx tsc --noEmit)",
      "Bash(npx eslint *)",
      "Bash(npx vitest *)",
      "Bash(npx playwright *)",
      "Bash(gh run list *)",
      "Bash(gh run view *)",
      "Bash(gh run watch *)",
      "Bash(gh workflow list *)",
      "Bash(gh workflow run *)",
      "Bash(gh pr list *)",
      "Bash(gh pr view *)",
      "Bash(gh issue list *)",
      "Bash(gh issue view *)",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git diff)",
      "Bash(git diff *)",
      "Bash(git log)",
      "Bash(git log *)",
      "Bash(git branch)",
      "Bash(git branch *)",
      "Bash(git show *)",
      "Bash(git stash)",
      "Bash(git stash *)",
      "Bash(supabase db diff)",
      "Bash(supabase db diff *)",
      "Bash(supabase migration list)",
      "Bash(wc *)",
      "Bash(ls *)"
    ]
  },

  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/block-secrets.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post-lint.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ]
  }
}
