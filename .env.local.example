# ─────────────────────────────────────────────────────────
# HopTrack Environment Variables Template
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────

# ── Production Supabase (default for `npm run dev`) ──────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Service role key — NEVER expose in client code.
# Required for: npm run setup, storage bucket creation, admin operations.
# Dashboard → Project Settings → API → service_role secret
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Project ref (for db:types and db:migrate commands)
# Dashboard → Project Settings → General → Reference ID
NEXT_PUBLIC_SUPABASE_REF=YOUR_PROJECT_REF

# ── Staging Supabase (used by `npm run dev:staging`) ─────
# Provision a separate Supabase project for staging.
# Riley: fill these in once the staging project is created.
STAGING_SUPABASE_URL=https://YOUR_STAGING_PROJECT_REF.supabase.co
STAGING_SUPABASE_ANON_KEY=your_staging_anon_key_here
STAGING_SUPABASE_SERVICE_ROLE_KEY=your_staging_service_role_key_here
STAGING_SUPABASE_PROJECT_REF=YOUR_STAGING_PROJECT_REF

# ── Production project ref (for db:migrate:production) ───
PRODUCTION_SUPABASE_PROJECT_REF=YOUR_PROJECT_REF

# ── Optional: Mapbox (for Explore map view — Sprint 10) ──
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_token_here

# ── Web Push (VAPID keys) ─────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_SUBJECT=mailto:push@hoptrack.beer

# ── Stripe (billing + subscriptions) ─────────────────────
# Dashboard → Developers → API Keys
# Secret key: sk_live_... (production) / sk_test_... (dev)
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
# Publishable key: pk_live_... / pk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
# Webhook secret — get from: stripe listen --forward-to localhost:3000/api/billing/webhook
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
# Price IDs — create in Stripe dashboard and paste here
# Monthly prices
STRIPE_PRICE_TAP_MONTHLY=price_tap_monthly_placeholder
STRIPE_PRICE_CASK_MONTHLY=price_cask_monthly_placeholder
# Annual prices (20% discount)
STRIPE_PRICE_TAP_ANNUAL=price_tap_annual_placeholder
STRIPE_PRICE_CASK_ANNUAL=price_cask_annual_placeholder
# Public site URL (for checkout redirect URLs)
NEXT_PUBLIC_SITE_URL=https://app.hoptrack.beer

# ── Resend (transactional email) ─────────────────────────
# Get API key from resend.com/api-keys
# Leave blank to disable email sending (dev mode: console.log)
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=HopTrack <hello@hoptrack.beer>

# ── Cron / Scheduled Jobs ────────────────────────────────
# Shared secret for authenticating cron endpoints (weekly digest, etc.)
# Generate with: openssl rand -hex 32
CRON_SECRET=your_cron_secret_here

# ── Anthropic (HopRoute AI) ─────────────────────────────
# Used for AI-generated brewery routes. Get from console.anthropic.com
# Leave blank to disable HopRoute generation
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── POS Integration (Toast + Square) ────────────────────
# Token encryption key — 64 hex chars (32 bytes). Generate with:
#   openssl rand -hex 32
POS_TOKEN_ENCRYPTION_KEY=your_64_hex_char_encryption_key_here

# Toast Partner API (requires Toast Partner Program approval)
TOAST_CLIENT_ID=your_toast_client_id_here
TOAST_CLIENT_SECRET=your_toast_client_secret_here
TOAST_WEBHOOK_SECRET=your_toast_webhook_secret_here

# Square Developer API (register at developer.squareup.com)
SQUARE_APP_ID=your_square_app_id_here
SQUARE_APP_SECRET=your_square_app_secret_here
SQUARE_WEBHOOK_SECRET=your_square_webhook_secret_here

# ── Optional: Edge Function secrets ──────────────────────
# These are set via Supabase dashboard or:
#   supabase secrets set MY_SECRET=value
# SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are auto-injected
# into Edge Functions — do not set them here for functions.
