# ─────────────────────────────────────────────────────────
# HopTrack — Production Environment Variables
# ─────────────────────────────────────────────────────────
# This documents every env var needed for a production deploy.
# Set these in your Vercel project settings (NOT in a file).
# NEVER commit real values to git.
# ─────────────────────────────────────────────────────────

# ── Supabase (REQUIRED) ─────────────────────────────────
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=                # public anon key
SUPABASE_SERVICE_ROLE_KEY=                    # secret — server-side only

# ── Sentry (REQUIRED) ──────────────────────────────────
# Error monitoring — get DSN from sentry.io project settings
NEXT_PUBLIC_SENTRY_DSN=https://YOUR_DSN@sentry.io/PROJECT_ID

# ── Web Push / VAPID (REQUIRED) ─────────────────────────
# Generate once: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=                 # public — safe for client
VAPID_PRIVATE_KEY=                            # secret — server-side only
VAPID_SUBJECT=mailto:push@hoptrack.beer

# ── Stripe Billing (REQUIRED for revenue) ───────────────
# Dashboard → Developers → API Keys
# Use sk_live_ and pk_live_ keys for production
STRIPE_SECRET_KEY=sk_live_...                 # secret — server-side only
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...  # public — safe for client
STRIPE_WEBHOOK_SECRET=whsec_...               # secret — from webhook endpoint config

# Price IDs — create products in Stripe dashboard first
# Tap tier: $49/mo, $470/yr (20% savings)
STRIPE_PRICE_TAP_MONTHLY=price_...
STRIPE_PRICE_TAP_ANNUAL=price_...
# Cask tier: $149/mo, $1,430/yr (20% savings)
STRIPE_PRICE_CASK_MONTHLY=price_...
STRIPE_PRICE_CASK_ANNUAL=price_...

# ── Site URL (REQUIRED) ─────────────────────────────────
# Used for Stripe checkout redirects, OG images, email links
NEXT_PUBLIC_SITE_URL=https://hoptrack.beer

# ── Resend Email (REQUIRED for transactional email) ─────
# Get API key from resend.com/api-keys
# Domain must be verified in Resend dashboard
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=HopTrack <hello@hoptrack.beer>

# ── Anthropic AI (REQUIRED for HopRoute) ────────────────
# AI-generated brewery routes — get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Cron / Scheduled Jobs (REQUIRED for weekly digest) ──
# Shared secret for authenticating cron endpoints. Also set in GitHub Actions secrets.
# Generate: openssl rand -hex 32
CRON_SECRET=

# ── POS Integration (REQUIRED if Toast/Square enabled) ──
# AES-256-GCM encryption key for POS provider tokens
# Generate: openssl rand -hex 32 (must be 64 hex chars / 32 bytes)
POS_TOKEN_ENCRYPTION_KEY=

# ── Optional ────────────────────────────────────────────
# Mapbox (Explore map view — only if map feature is enabled)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_token_here

# ─────────────────────────────────────────────────────────
# GITHUB ACTIONS SECRETS (not Vercel — set in repo settings)
# ─────────────────────────────────────────────────────────
# E2E test Supabase instance (separate from production)
# E2E_SUPABASE_URL=https://YOUR_E2E_PROJECT_REF.supabase.co
# E2E_SUPABASE_ANON_KEY=
# E2E_SUPABASE_SERVICE_ROLE_KEY=
#
# Cron job endpoint URLs (used by GitHub Actions scheduled workflows)
# DIGEST_ENDPOINT_URL=https://hoptrack.beer/api/cron/weekly-digest
# TRIAL_LIFECYCLE_ENDPOINT_URL=https://hoptrack.beer/api/cron/trial-lifecycle
# ONBOARDING_DRIP_ENDPOINT_URL=https://hoptrack.beer/api/cron/onboarding-drip
# AI_SUGGESTIONS_ENDPOINT_URL=https://hoptrack.beer/api/cron/ai-suggestions
#
# CRON_SECRET must also be set in GitHub Actions (shared with Vercel)

# ─────────────────────────────────────────────────────────
# DEPLOYMENT NOTES
# ─────────────────────────────────────────────────────────
# 1. Set all REQUIRED vars in Vercel → Project → Settings → Environment Variables
# 2. Mark server-only vars as non-public (no NEXT_PUBLIC_ prefix)
# 3. After first deploy: register Stripe webhook URL
#    → https://hoptrack.beer/api/billing/webhook
# 4. After Supabase changes: run NOTIFY pgrst, 'reload schema';
# 5. Supabase realtime must be enabled on: beers, beer_pour_sizes
# 6. Storage buckets (avatars, session-photos) must have RLS policies
#
# ── ENV VAR AUDIT (Sprint 151) ──────────────────────────
# Category: REQUIRED for launch
#   NEXT_PUBLIC_SUPABASE_URL, NEXT_PUBLIC_SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY
#   NEXT_PUBLIC_SENTRY_DSN, NEXT_PUBLIC_SITE_URL
#   NEXT_PUBLIC_VAPID_PUBLIC_KEY, VAPID_PRIVATE_KEY, VAPID_SUBJECT
#   RESEND_API_KEY, RESEND_FROM_EMAIL, CRON_SECRET
#
# Category: REQUIRED for revenue (blocked on LLC/Stripe)
#   STRIPE_SECRET_KEY, NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY
#   STRIPE_WEBHOOK_SECRET, STRIPE_PRICE_TAP_MONTHLY, STRIPE_PRICE_TAP_ANNUAL
#   STRIPE_PRICE_CASK_MONTHLY, STRIPE_PRICE_CASK_ANNUAL
#
# Category: REQUIRED for AI features
#   ANTHROPIC_API_KEY
#
# Category: REQUIRED for POS (post-launch)
#   POS_TOKEN_ENCRYPTION_KEY
#
# Category: OPTIONAL
#   NEXT_PUBLIC_MAPBOX_TOKEN
#
# Category: GitHub Actions secrets (not Vercel)
#   CRON_SECRET, E2E_SUPABASE_URL, E2E_SUPABASE_ANON_KEY
#   E2E_SUPABASE_SERVICE_ROLE_KEY, DIGEST_ENDPOINT_URL
#   TRIAL_LIFECYCLE_ENDPOINT_URL, ONBOARDING_DRIP_ENDPOINT_URL
#   AI_SUGGESTIONS_ENDPOINT_URL
# ─────────────────────────────────────────────────────────
